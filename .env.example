# フロントエンド（Vite）— リポジトリをクローンしたらコピーして使う:
#   cp .env.example .env.local
# Firebase Web クライアント設定（Firebase コンソールの「プロジェクトの設定」から取得）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# OpenAI API キーは Firebase Functions（functions/.env の OPENAI_API_KEY）で管理します。
# ブラウザに API キーを載せないため、VITE_OPENAI_API_KEY は不要です。
